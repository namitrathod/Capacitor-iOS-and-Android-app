{
  "name": "dxweb",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "serve:mobile": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build",
    "build:mobile": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
