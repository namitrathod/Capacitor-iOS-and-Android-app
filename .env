ENVIRONMENT=local
PROJECT_NAME=StarterKit-Angular-FastAPI-Material
DOMAIN=localhost

# CORS: allow Angular dev frontend + Capacitor mobile app (same Wi-Fi IP and WebView origins)
BACKEND_CORS_ORIGINS=http://localhost:4200,http://10.0.0.155:4200,capacitor://localhost,http://localhost

# PostgreSQL connection (matches existing local setup)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=java_test2

# Security
# Generated once for local dev; change for real deployments.
SECRET_KEY=dev-secret-change-this-key

# First superuser for initial_data.py
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=Admin123!

# Registration and email settings
USERS_OPEN_REGISTRATION=true
SMTP_HOST=
EMAILS_FROM_EMAIL=

